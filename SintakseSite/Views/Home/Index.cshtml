@model SintakseSite.Models.HomePageViewModel

@{
    ViewData["Title"] = "Sākums";
}


<style>
    .poster-button {
        position: relative;
        display: block;
        padding: 0;
        border: 0;
        border-radius: 6px;
        background: transparent;
        overflow: hidden;
        cursor: zoom-in;
    }

    .poster-image {
        display: block;
        width: 300px;
        height: auto;
        border-radius: 6px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.18);
        transition: transform 0.3s ease;
    }

    .poster-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        background: rgba(0, 0, 0, 0.35);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .poster-icon {
        display: flex;
        width: 54px;
        height: 54px;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.92);
        color: #171717;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
        transform: scale(0.9);
        transition: transform 0.3s ease;
    }

    .poster-button:hover .poster-image {
        transform: scale(1.03);
    }

    .poster-button:hover .poster-overlay {
        opacity: 1;
    }

    .poster-button:hover .poster-icon {
        transform: scale(1);
    }

    .author-frame {
        width: 280px;
        height: 373px;
        margin: 0 auto;
        overflow: hidden;
        border-radius: 4px;
    }

    .author-image {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(0);
        opacity: 1;
        transform: scale(1);
        transition: filter 0.7s ease, opacity 0.7s ease, transform 0.7s ease;
    }

    /* Datorā attēli melnbalti */
    @@media (min-width: 768px) {
        .author-image {
            filter: grayscale(100%);
            opacity: 0.9;
        }

        .author-card:hover .author-image {
            filter: grayscale(0);
            opacity: 1;
            transform: scale(1.02);
        }
    }
</style>

<section class="min-h-screen bg-stone-50 px-6">
    <div class="mx-auto flex min-h-screen max-w-6xl flex-col items-center justify-center text-center">

        <img src="/images/slogo3.png"
             alt="Sintakses Stupors"
             class="mx-auto h-40 w-auto" />

        <div class="my-10 h-px w-40 bg-neutral-300"></div>

        <h1 class="hero-title mt-4 text-5xl font-light tracking-tight text-neutral-950 md:text-6xl">
            Sintakses Stupors
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-neutral-600">
            Vieta literatūrai, autoriem un notikumiem.
        </p>

        <nav class="mt-16 flex flex-wrap justify-center gap-8 text-lg">
            <a href="#par-mums" class="transition hover:text-red-700 focus:outline-none">Par mums</a>
            <a href="#autori" class="transition hover:text-red-700 focus:outline-none">Autori</a>

            <a href="#pasakumi" class="transition hover:text-red-700 focus:outline-none">Pasākumi</a>
            <a asp-controller="Gallery"
               asp-action="Index">
                Galerija
            </a>
            <a href="#kontakti" class="transition hover:text-red-700 focus:outline-none">Kontakti</a>
           
        </nav>

    </div>
</section>

<section id="par-mums" class="border-t border-neutral-200 bg-stone-50 px-6 py-32">
    <div class="mx-auto grid max-w-6xl gap-16 md:grid-cols-[0.8fr_1.2fr]">

        <div>
            <p class="text-sm uppercase tracking-[0.35em] text-red-700">
                Par mums
            </p>

            <h2 class="hero-title mt-6 text-4xl font-light leading-tight text-neutral-950 md:text-6xl">
                Esam jau no 2024. gada
            </h2>
        </div>

        <div class="space-y-6 text-lg leading-8 text-neutral-700">
            <p>
                Sintakses Stupors ir aizrautīgu domubiedru uzturēta dzejas grupa, kurā rakstošie var dalīties ar saviem dzejoļiem un citiem tekstiem, savukārt lasošie – ar tiem baroties.
            </p>

            <p>
                Mēs rīkojam dzejas lasījumus, radošas tikšanās, pasākumus, publicējam savus tekstus un plānojam būt mūžīgi.
            </p>

            <p>
                Šī ir vieta mūsu autoriem, notikumiem, galerijām un kopīgajam ceļam literatūrā.
            </p>
        </div>

    </div>
</section>

<section id="autori"
         class="border-t border-neutral-200 bg-white px-6 py-32">

    <div class="mx-auto max-w-6xl">

        <div class="mb-16 text-center">
            <p class="text-sm uppercase tracking-[0.35em] text-red-700">
                Autori
            </p>
        </div>

        <div class="grid gap-x-10 gap-y-16 sm:grid-cols-2 lg:grid-cols-3">
            
            @foreach (var author in Model.Authors)
            {
                <article class="author-card text-center">

                    <div class="author-frame">
                        <img src="/images/Autori/@author.Image"
                             alt="@author.Name"
                             loading="lazy"
                             style="object-position: @author.ObjectPosition;"
                             class="author-image" />
                    </div>

                    <h3 class="mt-4 text-2xl text-neutral-950">
                        @author.Name
                    </h3>

                    <p class="mt-1 text-neutral-500">
                        @author.Categories
                    </p>

                </article>
            }

        </div>
    </div>
</section>

   
<section id="gallery" class="border-t border-neutral-200 bg-white px-6 py-32">

    <div class="mx-auto max-w-6xl">

        <div class="mb-20 text-center">

            <p class="text-sm uppercase tracking-[0.35em] text-red-700">
                Galerija
            </p>

            <h2 class="mt-6 text-5xl md:text-7xl font-light tracking-tight text-neutral-950">
                Atskats no pasākumiem
            </h2>

            <p class="mx-auto mt-8 max-w-3xl text-lg leading-8 text-neutral-600">
                Fotogrāfijas no Sintakses Stupora projektiem
            </p>

            <a asp-controller="Gallery"
               asp-action="Index"
               class="mt-12 inline-flex items-center gap-3 border border-neutral-300 px-6 py-3 text-sm uppercase tracking-[0.25em] text-neutral-700 transition-all duration-300 hover:border-red-700 hover:bg-red-700 hover:text-white">

                Skatīt galeriju
                <span aria-hidden="true">→</span>

            </a>

        </div>

    </div>

</section>
<section id="pasakumi"
         class="border-t border-neutral-200 bg-white px-6 py-32">

    <div class="mx-auto max-w-6xl">

        <div class="mb-20 text-center">
            <p class="text-sm uppercase tracking-[0.35em] text-red-700">
                Pasākumi
            </p>

            <h2 class="mt-6 text-5xl font-light tracking-tight text-neutral-950 md:text-7xl">
                Tuvākie notikumi
            </h2>
        </div>

        @if (Model.UpcomingEvents.Any())
        {
            <div class="space-y-32 lg:space-y-20">
                @foreach (var eventItem in Model.UpcomingEvents)
                {
                    <article class="grid items-start gap-12 lg:grid-cols-[300px_1fr]">

                        <div class="flex justify-center">
                            <button type="button"
                                    onclick="openPoster('@eventItem.PosterImage')"
                                    aria-label="Palielināt @eventItem.Title afišu"
                                    class="poster-button">

                                <img src="@eventItem.PosterImage"
                                     alt="@eventItem.Title afiša"
                                     class="poster-image" />

                                <span class="poster-overlay">
                                    <span class="poster-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                             width="24"
                                             height="24"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2"
                                             stroke-linecap="round"
                                             stroke-linejoin="round"
                                             aria-hidden="true">

                                            <circle cx="11" cy="11" r="7"></circle>
                                            <line x1="20"
                                                  y1="20"
                                                  x2="16.5"
                                                  y2="16.5">
                                            </line>
                                        </svg>
                                    </span>
                                </span>
                            </button>
                        </div>

                        <div>
                            <p class="text-sm uppercase tracking-[0.35em] text-red-700">
                                @eventItem.Date.ToString("dd.MM.yyyy")
                                ·
                                @eventItem.Time
                            </p>

                            <h3 class="mt-5 text-4xl font-light leading-tight text-neutral-950 md:text-5xl">
                                @eventItem.Title
                            </h3>

                            <p class="mt-6 text-lg leading-8 text-neutral-600">
                                @eventItem.Description
                            </p>

                            @if (!string.IsNullOrWhiteSpace(eventItem.Participants))
                            {
                                <div class="mt-8">
                                    <p class="text-sm uppercase tracking-[0.25em] text-red-700">
                                        Dzeju lasīs
                                    </p>

                                    <p class="mt-4 leading-8 text-neutral-600">
                                        @eventItem.Participants
                                    </p>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(eventItem.MusicalGuest))
                            {
                                <div class="mt-8">
                                    <p class="text-sm uppercase tracking-[0.25em] text-red-700">
                                        Muzikālais viesis
                                    </p>

                                    <p class="mt-4 text-lg text-neutral-700">
                                        @eventItem.MusicalGuest
                                    </p>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(eventItem.ExternalUrl))
                            {
                                <a href="@eventItem.ExternalUrl"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="mt-10 inline-flex items-center gap-3 border border-neutral-300 px-6 py-3 text-sm uppercase tracking-[0.25em] text-neutral-700 transition-all duration-300 hover:border-red-700 hover:bg-red-700 hover:text-white">

                                    @eventItem.ExternalLinkText
                                    <span aria-hidden="true">→</span>
                                </a>
                            }
                        </div>

                    </article>
                }
            </div>
        }
        else
        {
            <p class="text-center text-lg text-neutral-500">
                Pašlaik jauni pasākumi nav izziņoti.
            </p>
        }

        @if (Model.PastEvents.Any())
        {
            <div class="mt-40 border-y border-neutral-200 bg-neutral-100 px-6 py-20 sm:mt-48 sm:py-24 lg:mt-64 lg:px-12 lg:py-28">

                <div class="mb-16 text-center">
                    <p class="text-sm uppercase tracking-[0.35em] text-red-700">
                        Arhīvs
                    </p>

                    <h3 class="mt-5 text-4xl font-light text-neutral-950 md:text-5xl">
                        Notikušie pasākumi
                    </h3>
                </div>

                <div class="divide-y divide-neutral-200">

                    @foreach (var eventItem in Model.PastEvents)
                    {
                        <article class="grid gap-6 py-8 md:grid-cols-[160px_1fr_auto] md:items-center">

                            <div>
                                <p class="text-sm uppercase tracking-[0.2em] text-red-700">
                                    @eventItem.Date.ToString("dd.MM.yyyy")
                                </p>

                                <p class="mt-2 text-sm text-neutral-500">
                                    @eventItem.Time
                                </p>
                            </div>

                            <div>
                                <h4 class="text-3xl font-light text-neutral-950">
                                    @eventItem.Title
                                </h4>

                                <p class="mt-3 max-w-2xl leading-7 text-neutral-600">
                                    @eventItem.Description
                                </p>
                            </div>

                            <div>
                                @if (!string.IsNullOrWhiteSpace(eventItem.GallerySlug))
                                {
                                    <a asp-controller="Gallery"
                                       asp-action="Details"
                                       asp-route-slug="@eventItem.GallerySlug"
                                       class="inline-flex items-center gap-3 border border-neutral-300 px-5 py-3 text-sm uppercase tracking-[0.2em] text-neutral-700 transition-all duration-300 hover:border-red-700 hover:bg-red-700 hover:text-white">

                                        Skatīt galeriju
                                        <span aria-hidden="true">→</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-sm uppercase tracking-[0.2em] text-neutral-400">
                                        Galerija drīzumā
                                    </span>
                                }
                            </div>

                        </article>
                    }

                </div>
            </div>
        }

    </div>
</section>

